<Window x:Class="WindowsScreenRecorder.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:WindowsScreenRecorder.ViewModels"
        xmlns:conv="clr-namespace:WindowsScreenRecorder.Converters"
        mc:Ignorable="d"
        Title="Windows Screen Recorder"
        Width="860" Height="600"
        MinWidth="700" MinHeight="520"
        Background="{StaticResource SurfaceDeepBrush}"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <conv:RecordingStateToColorConverter x:Key="StateToColorConverter"/>
        <conv:RecordingStateToBoolConverter x:Key="StateToBoolConverter"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>
        <conv:LevelToWidthConverter x:Key="LevelToWidth"/>
        <conv:EnumToDisplayNameConverter x:Key="EnumToName"/>
    </Window.Resources>

    <Border CornerRadius="10" ClipToBounds="True">
        <Grid>
            <!-- Main content -->
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="38"/>   <!-- Title bar -->
                    <RowDefinition Height="*"/>    <!-- Content -->
                    <RowDefinition Height="Auto"/> <!-- Status bar -->
                </Grid.RowDefinitions>

                <!-- ─── Custom Title Bar ──────────────────────────────────── -->
                <Border Grid.Row="0"
                        Background="{StaticResource SurfaceDeepBrush}"
                        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid Margin="12,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <!-- App icon (red dot = camera) -->
                            <Ellipse Width="10" Height="10"
                                     Fill="{StaticResource AccentRedBrush}"
                                     Margin="0,0,8,0"/>
                            <TextBlock Text="Windows Screen Recorder"
                                       Style="{StaticResource TextBody}"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Window controls -->
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center">
                            <Button Style="{StaticResource IconButtonStyle}"
                                    Click="MinimizeButton_Click"
                                    ToolTip="Minimize"
                                    Width="30" Height="30">
                                <Path Data="M 4,14 L 20,14"
                                      Stroke="{StaticResource TextSecondaryBrush}"
                                      StrokeThickness="1.5"/>
                            </Button>
                            <Button Style="{StaticResource IconButtonStyle}"
                                    Click="MaximizeButton_Click"
                                    ToolTip="Maximize"
                                    Width="30" Height="30">
                                <Rectangle Width="10" Height="10"
                                           Stroke="{StaticResource TextSecondaryBrush}"
                                           StrokeThickness="1.5"
                                           Fill="Transparent"/>
                            </Button>
                            <Button Style="{StaticResource IconButtonStyle}"
                                    Click="CloseButton_Click"
                                    ToolTip="Close"
                                    Width="30" Height="30">
                                <Path Data="M 4,4 L 20,20 M 20,4 L 4,20"
                                      Stroke="{StaticResource TextSecondaryBrush}"
                                      StrokeThickness="1.5"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ─── Main Content ───────────────────────────────────────── -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>  <!-- Left sidebar -->
                        <ColumnDefinition Width="*"/>    <!-- Center -->
                    </Grid.ColumnDefinitions>

                    <!-- Left Sidebar -->
                    <Border Grid.Column="0"
                            Background="{StaticResource SurfacePrimaryBrush}"
                            BorderBrush="{StaticResource SurfaceBorderBrush}"
                            BorderThickness="0,0,1,0">
                        <StackPanel Margin="12">

                            <!-- Capture Mode -->
                            <TextBlock Text="CAPTURE MODE"
                                       Style="{StaticResource TextCaption}"
                                       Margin="0,0,0,6"
                                       FontWeight="SemiBold"
                                       LetterSpacing="1"/>

                            <RadioButton Content="Full Desktop"
                                         IsChecked="{Binding CaptureMode,
                                             Converter={StaticResource EnumToName},
                                             ConverterParameter=FullDesktop}"
                                         Foreground="{StaticResource TextPrimaryBrush}"
                                         Margin="0,2"/>
                            <RadioButton Content="Single Monitor"
                                         IsChecked="{Binding CaptureMode,
                                             Converter={StaticResource EnumToName},
                                             ConverterParameter=SingleMonitor}"
                                         Foreground="{StaticResource TextPrimaryBrush}"
                                         Margin="0,2"/>
                            <ComboBox ItemsSource="{Binding Monitors}"
                                      SelectedItem="{Binding SelectedMonitor}"
                                      Style="{StaticResource ModernComboBoxStyle}"
                                      Margin="12,2,0,4"
                                      IsEnabled="{Binding CaptureMode,
                                          Converter={StaticResource EnumToName},
                                          ConverterParameter=SingleMonitor}"/>

                            <RadioButton Content="Application Window"
                                         IsChecked="{Binding CaptureMode,
                                             Converter={StaticResource EnumToName},
                                             ConverterParameter=ApplicationWindow}"
                                         Foreground="{StaticResource TextPrimaryBrush}"
                                         Margin="0,2"/>
                            <ComboBox ItemsSource="{Binding CapturableWindows}"
                                      SelectedItem="{Binding SelectedWindow}"
                                      Style="{StaticResource ModernComboBoxStyle}"
                                      Margin="12,2,0,8"
                                      IsEnabled="{Binding CaptureMode,
                                          Converter={StaticResource EnumToName},
                                          ConverterParameter=ApplicationWindow}"/>

                            <Separator Style="{StaticResource DividerStyle}"/>

                            <!-- Audio -->
                            <TextBlock Text="AUDIO"
                                       Style="{StaticResource TextCaption}"
                                       Margin="0,4,0,6"
                                       FontWeight="SemiBold"/>

                            <TextBlock Text="Output Device"
                                       Style="{StaticResource TextCaption}"
                                       Margin="0,0,0,3"/>
                            <ComboBox ItemsSource="{Binding AudioOutputDevices}"
                                      SelectedItem="{Binding SelectedAudioOutput}"
                                      Style="{StaticResource ModernComboBoxStyle}"
                                      Margin="0,0,0,4"/>

                            <!-- System audio level meter -->
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="28"/>
                                </Grid.ColumnDefinitions>
                                <ProgressBar Grid.Column="0"
                                             Style="{StaticResource LevelMeterStyle}"
                                             Value="{Binding SystemAudioLevel}"
                                             Maximum="1"
                                             VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding SystemAudioLevel, StringFormat={}{0:P0}}"
                                           Style="{StaticResource TextCaption}"
                                           HorizontalAlignment="Right"
                                           Margin="4,0,0,0"/>
                            </Grid>

                            <TextBlock Text="Microphone"
                                       Style="{StaticResource TextCaption}"
                                       Margin="0,0,0,3"/>
                            <ComboBox ItemsSource="{Binding MicrophoneDevices}"
                                      SelectedItem="{Binding SelectedMicrophone}"
                                      Style="{StaticResource ModernComboBoxStyle}"
                                      Margin="0,0,0,4"/>

                            <!-- Mic level meter -->
                            <ProgressBar Style="{StaticResource LevelMeterStyle}"
                                         Value="{Binding MicrophoneLevel}"
                                         Maximum="1"
                                         Margin="0,0,0,8"/>

                            <Separator Style="{StaticResource DividerStyle}"/>

                            <!-- Output folder -->
                            <TextBlock Text="OUTPUT FOLDER"
                                       Style="{StaticResource TextCaption}"
                                       Margin="0,4,0,6"
                                       FontWeight="SemiBold"/>

                            <Border Background="{StaticResource SurfaceElevatedBrush}"
                                    BorderBrush="{StaticResource SurfaceBorderBrush}"
                                    BorderThickness="1" CornerRadius="6"
                                    Padding="8,6" Margin="0,0,0,4">
                                <TextBlock Text="{Binding OutputFolder}"
                                           TextTrimming="CharacterEllipsis"
                                           Style="{StaticResource TextCaption}"
                                           ToolTip="{Binding OutputFolder}"/>
                            </Border>

                            <Button Content="Open Folder"
                                    Style="{StaticResource ActionButtonStyle}"
                                    Command="{Binding OpenOutputFolderCommand}"
                                    HorizontalAlignment="Stretch"
                                    Margin="0,0,0,4"/>

                            <!-- Settings -->
                            <Button Content="⚙ Settings"
                                    Style="{StaticResource ActionButtonStyle}"
                                    Command="{Binding OpenSettingsCommand}"
                                    HorizontalAlignment="Stretch"
                                    Margin="0,4,0,0"/>

                            <!-- GPU Info -->
                            <TextBlock Text="{Binding GpuInfo}"
                                       Style="{StaticResource TextCaption}"
                                       TextWrapping="Wrap"
                                       Margin="0,8,0,0"
                                       Foreground="{StaticResource TextDisabledBrush}"/>
                        </StackPanel>
                    </Border>

                    <!-- Center Content -->
                    <Grid Grid.Column="1" Margin="24">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Recording Timer + Status -->
                        <StackPanel Grid.Row="0"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Center">

                            <!-- Status indicator dot + label -->
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        Margin="0,0,0,16">
                                <Ellipse x:Name="StatusDot"
                                         Width="10" Height="10"
                                         Fill="{Binding RecordingState,
                                             Converter={StaticResource StateToColorConverter}}"
                                         VerticalAlignment="Center"
                                         Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding StatusMessage}"
                                           Style="{StaticResource TextBody}"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- Timer display -->
                            <TextBlock Text="{Binding RecordingTimer}"
                                       Style="{StaticResource TextTimer}"
                                       Margin="0,0,0,32"/>

                            <!-- Control Buttons Row -->
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        Margin="0,0,0,16">

                                <!-- Record / Stop based on state -->
                                <Button Command="{Binding StartRecordingCommand}"
                                        Style="{StaticResource RecordButtonStyle}"
                                        Width="100"
                                        Visibility="{Binding RecordingState,
                                            Converter={StaticResource StateToBoolConverter},
                                            ConverterParameter=Idle}">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="8" Height="8"
                                                 Fill="White"
                                                 VerticalAlignment="Center"
                                                 Margin="0,0,6,0"/>
                                        <TextBlock Text="Record" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <!-- Pause / Resume -->
                                <Button Command="{Binding PauseRecordingCommand}"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Width="90"
                                        Margin="8,0"
                                        Visibility="{Binding RecordingState,
                                            Converter={StaticResource StateToBoolConverter},
                                            ConverterParameter=NotIdle}">
                                    <TextBlock Text="{Binding RecordingState,
                                        Converter={StaticResource EnumToName},
                                        ConverterParameter=PauseLabel}"/>
                                </Button>

                                <!-- Stop -->
                                <Button Command="{Binding StopRecordingCommand}"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Width="80"
                                        Visibility="{Binding RecordingState,
                                            Converter={StaticResource StateToBoolConverter},
                                            ConverterParameter=NotIdle}">
                                    <StackPanel Orientation="Horizontal">
                                        <Rectangle Width="8" Height="8"
                                                   Fill="{StaticResource AccentRedBrush}"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,6,0"/>
                                        <TextBlock Text="Stop" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>

                            <!-- Screenshot button -->
                            <Button Content="📸 Screenshot"
                                    Style="{StaticResource ActionButtonStyle}"
                                    Command="{Binding TakeScreenshotCommand}"
                                    HorizontalAlignment="Center"
                                    Margin="0,0,0,0"/>
                        </StackPanel>

                        <!-- Live Stats Row -->
                        <Border Grid.Row="1"
                                Style="{StaticResource CardStyle}"
                                Margin="0,8,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="FILE SIZE" Style="{StaticResource TextCaption}"/>
                                    <TextBlock Text="{Binding Stats.FileSizeFormatted}"
                                               Style="{StaticResource TextBody}"
                                               FontWeight="SemiBold"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="CPU" Style="{StaticResource TextCaption}"/>
                                    <TextBlock Text="{Binding Stats.CpuUsagePercent, StringFormat={}{0:F1}%}"
                                               Style="{StaticResource TextBody}"
                                               FontWeight="SemiBold"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="MEMORY" Style="{StaticResource TextCaption}"/>
                                    <TextBlock Text="{Binding Stats.MemoryUsageMB, StringFormat={}{0:F0} MB}"
                                               Style="{StaticResource TextBody}"
                                               FontWeight="SemiBold"/>
                                </StackPanel>

                                <StackPanel Grid.Column="3">
                                    <TextBlock Text="DISK FREE" Style="{StaticResource TextCaption}"/>
                                    <TextBlock Text="{Binding Stats.DiskSpaceFormatted}"
                                               Style="{StaticResource TextBody}"
                                               FontWeight="SemiBold"/>
                                </StackPanel>

                                <StackPanel Grid.Column="4">
                                    <TextBlock Text="FPS" Style="{StaticResource TextCaption}"/>
                                    <TextBlock Text="{Binding Stats.EncoderFps, StringFormat={}{0:F0}}"
                                               Style="{StaticResource TextBody}"
                                               FontWeight="SemiBold"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>

                <!-- Status bar -->
                <Border Grid.Row="2"
                        Background="{StaticResource SurfaceDeepBrush}"
                        BorderBrush="{StaticResource SurfaceBorderBrush}"
                        BorderThickness="0,1,0,0"
                        Padding="12,4">
                    <Grid>
                        <TextBlock Text="{Binding Stats.Duration, StringFormat=Duration: {0:hh\\:mm\\:ss}}"
                                   Style="{StaticResource TextCaption}"
                                   HorizontalAlignment="Left"/>
                        <TextBlock Text="F8 Record  F9 Pause  F10 Stop  F11 Screenshot"
                                   Style="{StaticResource TextCaption}"
                                   HorizontalAlignment="Center"
                                   Foreground="{StaticResource TextDisabledBrush}"/>
                        <TextBlock Text="{Binding Stats.DiskSpaceFormatted}"
                                   Style="{StaticResource TextCaption}"
                                   HorizontalAlignment="Right"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- ─── Notification Toast ─────────────────────────────────────── -->
            <Border HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    Margin="0,50,0,0"
                    MinWidth="280" MaxWidth="420"
                    CornerRadius="8"
                    Padding="14,10"
                    BorderThickness="1"
                    Visibility="{Binding NotificationVisible,
                        Converter={StaticResource BoolToVis}}"
                    Panel.ZIndex="100">
                <Border.Background>
                    <SolidColorBrush Color="{StaticResource SurfaceElevatedColor}"
                                     Opacity="0.95"/>
                </Border.Background>
                <Border.BorderBrush>
                    <Binding Path="NotificationIsError">
                        <Binding.Converter>
                            <conv:BoolToBrushConverter TrueBrush="{StaticResource StatusErrorBrush}"
                                                        FalseBrush="{StaticResource SurfaceBorderBrush}"/>
                        </Binding.Converter>
                    </Binding>
                </Border.BorderBrush>
                <TextBlock Text="{Binding NotificationMessage}"
                           Style="{StaticResource TextBody}"
                           TextWrapping="Wrap"/>
            </Border>

            <!-- ─── Settings Overlay ──────────────────────────────────────── -->
            <Border Background="#88000000"
                    Visibility="{Binding IsSettingsOpen,
                        Converter={StaticResource BoolToVis}}"
                    Panel.ZIndex="200"
                    MouseLeftButtonDown="SettingsOverlay_MouseLeftButtonDown"/>

            <!-- Settings Panel -->
            <Border Margin="0,0,0,0"
                    Width="380"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Stretch"
                    Background="{StaticResource SurfacePrimaryBrush}"
                    BorderBrush="{StaticResource SurfaceBorderBrush}"
                    BorderThickness="1,0,0,0"
                    Panel.ZIndex="201"
                    Visibility="{Binding IsSettingsOpen,
                        Converter={StaticResource BoolToVis}}">
                <Border.RenderTransform>
                    <TranslateTransform/>
                </Border.RenderTransform>
                <local:SettingsPanel xmlns:local="clr-namespace:WindowsScreenRecorder.Views.Controls"/>
            </Border>

        </Grid>
    </Border>
</Window>
