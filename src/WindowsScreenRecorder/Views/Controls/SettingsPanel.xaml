<UserControl x:Class="WindowsScreenRecorder.Views.Controls.SettingsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:WindowsScreenRecorder.ViewModels"
             xmlns:conv="clr-namespace:WindowsScreenRecorder.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="380">

    <UserControl.Resources>
        <conv:EnumToDisplayNameConverter x:Key="EnumToName"/>
        <conv:BoolToVisibilityConverter  x:Key="BoolToVis"/>

        <!-- Section header style -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Variable Text"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#888888"/>
            <Setter Property="Margin" Value="0,16,0,8"/>
            <Setter Property="TextTransform" Value="Uppercase"/>
            <Setter Property="LetterSpacing" Value="1"/>
        </Style>

        <!-- Label style -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Variable Text"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Row container -->
        <Style x:Key="FieldRow" TargetType="Grid">
            <Setter Property="Margin" Value="0,4,0,4"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>   <!-- Panel header -->
            <RowDefinition Height="*"/>    <!-- Scrollable content -->
            <RowDefinition Height="60"/>   <!-- Footer buttons -->
        </Grid.RowDefinitions>

        <!-- ─── Panel Header ────────────────────────────────────────────────── -->
        <Border Grid.Row="0"
                BorderBrush="#2A2A2A"
                BorderThickness="0,0,0,1"
                Padding="16,0">
            <Grid>
                <TextBlock Text="Settings"
                           FontFamily="Segoe UI Variable Display"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="#FFFFFF"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ─── Scrollable Settings Content ─────────────────────────────────── -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="16,0">
            <StackPanel Margin="0,8,0,8">

                <!-- ══ VIDEO ══════════════════════════════════════════════════ -->
                <TextBlock Text="VIDEO" Style="{StaticResource SectionHeader}"/>

                <!-- Frame Rate -->
                <TextBlock Text="Frame Rate" Style="{StaticResource FieldLabel}"/>
                <ComboBox ItemsSource="{Binding FrameRates}"
                          SelectedItem="{Binding FrameRate}"
                          Margin="0,0,0,8">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Converter={StaticResource EnumToName}}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <!-- Resolution -->
                <TextBlock Text="Resolution" Style="{StaticResource FieldLabel}"/>
                <ComboBox ItemsSource="{Binding ResolutionPresets}"
                          SelectedItem="{Binding Resolution}"
                          Margin="0,0,0,8">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Converter={StaticResource EnumToName}}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <!-- Custom resolution (visible only when Custom selected) -->
                <Grid Margin="0,0,0,8"
                      Visibility="{Binding IsCustomResolution, Converter={StaticResource BoolToVis}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Width (px)" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding CustomWidth, UpdateSourceTrigger=PropertyChanged}"
                                 Background="#1A1A1A" Foreground="#FFFFFF"
                                 BorderBrush="#333333" BorderThickness="1"
                                 Padding="6,4" CornerRadius="4"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Height (px)" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding CustomHeight, UpdateSourceTrigger=PropertyChanged}"
                                 Background="#1A1A1A" Foreground="#FFFFFF"
                                 BorderBrush="#333333" BorderThickness="1"
                                 Padding="6,4" CornerRadius="4"/>
                    </StackPanel>
                </Grid>

                <!-- Codec -->
                <TextBlock Text="Video Codec" Style="{StaticResource FieldLabel}"/>
                <ComboBox ItemsSource="{Binding VideoCodecs}"
                          SelectedItem="{Binding VideoCodec}"
                          Margin="0,0,0,8">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Converter={StaticResource EnumToName}}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <!-- Container Format -->
                <TextBlock Text="Container Format" Style="{StaticResource FieldLabel}"/>
                <ComboBox ItemsSource="{Binding ContainerFormats}"
                          SelectedItem="{Binding ContainerFormat}"
                          Margin="0,0,0,8">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Converter={StaticResource EnumToName}}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <!-- Quality -->
                <TextBlock Text="Quality Preset" Style="{StaticResource FieldLabel}"/>
                <ComboBox ItemsSource="{Binding QualityPresets}"
                          SelectedItem="{Binding Quality}"
                          Margin="0,0,0,8">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Converter={StaticResource EnumToName}}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <!-- Video Bitrate -->
                <TextBlock Text="Video Bitrate (Kbps)" Style="{StaticResource FieldLabel}"/>
                <TextBox Text="{Binding VideoBitrateKbps, UpdateSourceTrigger=PropertyChanged}"
                         Background="#1A1A1A" Foreground="#FFFFFF"
                         BorderBrush="#333333" BorderThickness="1"
                         Padding="6,4" CornerRadius="4" Margin="0,0,0,8"/>

                <!-- Hardware Acceleration -->
                <TextBlock Text="Hardware Acceleration" Style="{StaticResource FieldLabel}"/>
                <CheckBox Content="Auto-detect hardware encoder"
                          IsChecked="{Binding AutoDetectHardware}"
                          Foreground="#CCCCCC" Margin="0,0,0,8"/>
                <ComboBox ItemsSource="{Binding Accelerators}"
                          SelectedItem="{Binding PreferredAccelerator}"
                          Margin="0,0,0,8">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Converter={StaticResource EnumToName}}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <!-- ══ AUDIO ══════════════════════════════════════════════════ -->
                <TextBlock Text="AUDIO" Style="{StaticResource SectionHeader}"/>

                <TextBlock Text="Audio Mode" Style="{StaticResource FieldLabel}"/>
                <ComboBox ItemsSource="{Binding AudioCaptureModes}"
                          SelectedItem="{Binding AudioCaptureMode}"
                          Margin="0,0,0,8">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Converter={StaticResource EnumToName}}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <!-- System Volume -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="40"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="System Audio Volume" Style="{StaticResource FieldLabel}"/>
                        <Slider Minimum="0" Maximum="1" Value="{Binding SystemVolume}"
                                SmallChange="0.05" LargeChange="0.1"
                                TickFrequency="0.1"/>
                    </StackPanel>
                    <TextBlock Grid.Column="1"
                               Text="{Binding SystemVolume, StringFormat={}{0:P0}}"
                               Style="{StaticResource FieldLabel}"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Bottom"/>
                </Grid>

                <!-- Microphone Volume -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="40"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Microphone Volume" Style="{StaticResource FieldLabel}"/>
                        <Slider Minimum="0" Maximum="1" Value="{Binding MicrophoneVolume}"
                                SmallChange="0.05" LargeChange="0.1"
                                TickFrequency="0.1"/>
                    </StackPanel>
                    <TextBlock Grid.Column="1"
                               Text="{Binding MicrophoneVolume, StringFormat={}{0:P0}}"
                               Style="{StaticResource FieldLabel}"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Bottom"/>
                </Grid>

                <CheckBox Content="Enable noise suppression"
                          IsChecked="{Binding NoiseSuppressionEnabled}"
                          Foreground="#CCCCCC" Margin="0,0,0,8"/>

                <CheckBox Content="Enable push-to-talk"
                          IsChecked="{Binding PushToTalkEnabled}"
                          Foreground="#CCCCCC" Margin="0,0,0,8"/>

                <!-- Push-to-talk key (visible when enabled) -->
                <StackPanel Visibility="{Binding PushToTalkEnabled, Converter={StaticResource BoolToVis}}"
                            Margin="0,0,0,8">
                    <TextBlock Text="Push-to-Talk Key" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding PushToTalkKey}"
                             Background="#1A1A1A" Foreground="#FFFFFF"
                             BorderBrush="#333333" BorderThickness="1"
                             Padding="6,4" CornerRadius="4"/>
                </StackPanel>

                <!-- ══ MOUSE ══════════════════════════════════════════════════ -->
                <TextBlock Text="MOUSE" Style="{StaticResource SectionHeader}"/>

                <CheckBox Content="Record cursor"
                          IsChecked="{Binding RecordCursor}"
                          Foreground="#CCCCCC" Margin="0,0,0,8"/>

                <CheckBox Content="Highlight cursor"
                          IsChecked="{Binding HighlightCursor}"
                          Foreground="#CCCCCC" Margin="0,0,0,8"/>

                <CheckBox Content="Show click effects"
                          IsChecked="{Binding ShowClickEffects}"
                          Foreground="#CCCCCC" Margin="0,0,0,8"/>

                <StackPanel Visibility="{Binding ShowClickEffects, Converter={StaticResource BoolToVis}}"
                            Margin="0,0,0,8">
                    <TextBlock Text="Left Click Effect" Style="{StaticResource FieldLabel}"/>
                    <ComboBox ItemsSource="{Binding ClickEffects}"
                              SelectedItem="{Binding LeftClickEffect}"
                              Margin="0,0,0,8">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Converter={StaticResource EnumToName}}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <TextBlock Text="Right Click Effect" Style="{StaticResource FieldLabel}"/>
                    <ComboBox ItemsSource="{Binding ClickEffects}"
                              SelectedItem="{Binding RightClickEffect}"
                              Margin="0,0,0,8">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Converter={StaticResource EnumToName}}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>

                <CheckBox Content="Enable cursor zoom"
                          IsChecked="{Binding EnableCursorZoom}"
                          Foreground="#CCCCCC" Margin="0,0,0,8"/>

                <!-- ══ OUTPUT ═════════════════════════════════════════════════ -->
                <TextBlock Text="OUTPUT" Style="{StaticResource SectionHeader}"/>

                <TextBlock Text="Output Directory" Style="{StaticResource FieldLabel}"/>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="80"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             Text="{Binding OutputDirectory}"
                             Background="#1A1A1A" Foreground="#FFFFFF"
                             BorderBrush="#333333" BorderThickness="1"
                             Padding="6,4" CornerRadius="4"
                             IsReadOnly="True"/>
                    <Button Grid.Column="2"
                            Content="Browse..."
                            Command="{Binding BrowseOutputDirectoryCommand}"
                            Background="#242424" Foreground="#FFFFFF"
                            BorderBrush="#333333" BorderThickness="1"
                            Padding="8,4" CornerRadius="4" Cursor="Hand"/>
                </Grid>

                <TextBlock Text="Filename Format" Style="{StaticResource FieldLabel}"/>
                <TextBox Text="{Binding FilenameFormat}"
                         Background="#1A1A1A" Foreground="#FFFFFF"
                         BorderBrush="#333333" BorderThickness="1"
                         Padding="6,4" CornerRadius="4" Margin="0,0,0,8"/>

                <!-- ══ HOTKEYS ════════════════════════════════════════════════ -->
                <TextBlock Text="HOTKEYS" Style="{StaticResource SectionHeader}"/>

                <TextBlock Text="Start Recording" Style="{StaticResource FieldLabel}"/>
                <TextBox Text="{Binding HotkeyStart}"
                         Background="#1A1A1A" Foreground="#FFFFFF"
                         BorderBrush="#333333" BorderThickness="1"
                         Padding="6,4" CornerRadius="4" Margin="0,0,0,8"/>

                <TextBlock Text="Pause Recording" Style="{StaticResource FieldLabel}"/>
                <TextBox Text="{Binding HotkeyPause}"
                         Background="#1A1A1A" Foreground="#FFFFFF"
                         BorderBrush="#333333" BorderThickness="1"
                         Padding="6,4" CornerRadius="4" Margin="0,0,0,8"/>

                <TextBlock Text="Stop Recording" Style="{StaticResource FieldLabel}"/>
                <TextBox Text="{Binding HotkeyStop}"
                         Background="#1A1A1A" Foreground="#FFFFFF"
                         BorderBrush="#333333" BorderThickness="1"
                         Padding="6,4" CornerRadius="4" Margin="0,0,0,8"/>

                <TextBlock Text="Screenshot" Style="{StaticResource FieldLabel}"/>
                <TextBox Text="{Binding HotkeyScreenshot}"
                         Background="#1A1A1A" Foreground="#FFFFFF"
                         BorderBrush="#333333" BorderThickness="1"
                         Padding="6,4" CornerRadius="4" Margin="0,0,0,8"/>

                <!-- ══ TIMING ═════════════════════════════════════════════════ -->
                <TextBlock Text="TIMING" Style="{StaticResource SectionHeader}"/>

                <TextBlock Text="Countdown (seconds)" Style="{StaticResource FieldLabel}"/>
                <Slider Minimum="0" Maximum="10" Value="{Binding CountdownSeconds}"
                        IsSnapToTickEnabled="True" TickFrequency="1"
                        Margin="0,0,0,4"/>
                <TextBlock Text="{Binding CountdownSeconds, StringFormat={}{0} sec}"
                           Foreground="#888888" FontSize="11" Margin="0,0,0,8"/>

                <CheckBox Content="Auto-stop recording"
                          IsChecked="{Binding AutoStopEnabled}"
                          Foreground="#CCCCCC" Margin="0,0,0,8"/>

                <StackPanel Visibility="{Binding AutoStopEnabled, Converter={StaticResource BoolToVis}}"
                            Margin="0,0,0,8">
                    <TextBlock Text="Auto-stop after (minutes)" Style="{StaticResource FieldLabel}"/>
                    <Slider Minimum="1" Maximum="480" Value="{Binding AutoStopMinutes}"
                            IsSnapToTickEnabled="True" TickFrequency="1"
                            Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding AutoStopMinutes, StringFormat={}{0} min}"
                               Foreground="#888888" FontSize="11"/>
                </StackPanel>

                <!-- ══ MAINTENANCE ════════════════════════════════════════════ -->
                <TextBlock Text="MAINTENANCE" Style="{StaticResource SectionHeader}"/>

                <CheckBox Content="Auto-delete old recordings"
                          IsChecked="{Binding AutoDeleteOldRecordings}"
                          Foreground="#CCCCCC" Margin="0,0,0,8"/>

                <StackPanel Visibility="{Binding AutoDeleteOldRecordings, Converter={StaticResource BoolToVis}}"
                            Margin="0,0,0,8">
                    <TextBlock Text="Delete recordings older than (days)" Style="{StaticResource FieldLabel}"/>
                    <Slider Minimum="1" Maximum="365" Value="{Binding AutoDeleteAfterDays}"
                            IsSnapToTickEnabled="True" TickFrequency="1"
                            Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding AutoDeleteAfterDays, StringFormat={}{0} days}"
                               Foreground="#888888" FontSize="11"/>
                </StackPanel>

                <!-- ══ WEBCAM ══════════════════════════════════════════════════ -->
                <TextBlock Text="WEBCAM OVERLAY" Style="{StaticResource SectionHeader}"/>

                <CheckBox Content="Enable webcam overlay"
                          IsChecked="{Binding WebcamEnabled}"
                          Foreground="#CCCCCC" Margin="0,0,0,8"/>

                <StackPanel Visibility="{Binding WebcamEnabled, Converter={StaticResource BoolToVis}}"
                            Margin="0,0,0,8">

                    <TextBlock Text="Border Style" Style="{StaticResource FieldLabel}"/>
                    <ComboBox ItemsSource="{Binding BorderStyles}"
                              SelectedItem="{Binding WebcamBorder}"
                              Margin="0,0,0,8">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Converter={StaticResource EnumToName}}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <TextBlock Text="Opacity" Style="{StaticResource FieldLabel}"/>
                    <Slider Minimum="0.1" Maximum="1" Value="{Binding WebcamOpacity}"
                            SmallChange="0.05" TickFrequency="0.1"
                            Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding WebcamOpacity, StringFormat={}{0:P0}}"
                               Foreground="#888888" FontSize="11" Margin="0,0,0,8"/>
                </StackPanel>

                <!-- ══ APPEARANCE ═════════════════════════════════════════════ -->
                <TextBlock Text="APPEARANCE" Style="{StaticResource SectionHeader}"/>

                <TextBlock Text="Theme" Style="{StaticResource FieldLabel}"/>
                <ComboBox ItemsSource="{Binding Themes}"
                          SelectedItem="{Binding Theme}"
                          Margin="0,0,0,8">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Converter={StaticResource EnumToName}}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <CheckBox Content="Minimize to tray when recording"
                          IsChecked="{Binding MinimizeToTrayOnRecord}"
                          Foreground="#CCCCCC" Margin="0,0,0,8"/>

                <CheckBox Content="Check for updates on startup"
                          IsChecked="{Binding CheckForUpdatesOnStartup}"
                          Foreground="#CCCCCC" Margin="0,0,16,8"/>

            </StackPanel>
        </ScrollViewer>

        <!-- ─── Footer Buttons ───────────────────────────────────────────────── -->
        <Border Grid.Row="2"
                BorderBrush="#2A2A2A"
                BorderThickness="0,1,0,0"
                Padding="16,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="Reset to Defaults"
                        Command="{Binding ResetToDefaultsCommand}"
                        Background="Transparent"
                        Foreground="#888888"
                        BorderBrush="#333333" BorderThickness="1"
                        Padding="12,8" CornerRadius="6" Cursor="Hand"/>

                <Button Grid.Column="2"
                        Content="Save Settings"
                        Command="{Binding SaveCommand}"
                        Background="#3D8EFF"
                        Foreground="#FFFFFF"
                        BorderThickness="0"
                        Padding="16,8" CornerRadius="6" Cursor="Hand"
                        FontWeight="SemiBold"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
