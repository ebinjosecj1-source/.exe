<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════════
         DARK THEME (default — Windows 11 recorder aesthetic)
         Primary surface: #1A1A1A (near-black, not pure)
         Accent: #E8284F (recording red — purposeful, not generic)
         Secondary accent: #3D8EFF (action blue)
    ═══════════════════════════════════════════════════════════════ -->

    <!-- Surfaces -->
    <Color x:Key="SurfaceDeepColor">#FF111111</Color>
    <Color x:Key="SurfacePrimaryColor">#FF1A1A1A</Color>
    <Color x:Key="SurfaceElevatedColor">#FF242424</Color>
    <Color x:Key="SurfaceBorderColor">#FF2E2E2E</Color>
    <Color x:Key="SurfaceHoverColor">#FF303030</Color>

    <!-- Text -->
    <Color x:Key="TextPrimaryColor">#FFF5F5F5</Color>
    <Color x:Key="TextSecondaryColor">#FF9A9A9A</Color>
    <Color x:Key="TextDisabledColor">#FF555555</Color>
    <Color x:Key="TextInvertedColor">#FF111111</Color>

    <!-- Accent — Recording Red -->
    <Color x:Key="AccentRedColor">#FFE8284F</Color>
    <Color x:Key="AccentRedHoverColor">#FFFF3F63</Color>
    <Color x:Key="AccentRedPressedColor">#FFB81E3C</Color>
    <Color x:Key="AccentRedSubtleColor">#261E293A</Color>

    <!-- Accent — Action Blue -->
    <Color x:Key="AccentBlueColor">#FF3D8EFF</Color>
    <Color x:Key="AccentBlueHoverColor">#FF5BA3FF</Color>
    <Color x:Key="AccentBluePressedColor">#FF2472E0</Color>

    <!-- Status colors -->
    <Color x:Key="StatusRecordingColor">#FFE8284F</Color>
    <Color x:Key="StatusPausedColor">#FFF5A623</Color>
    <Color x:Key="StatusIdleColor">#FF3A3A3A</Color>
    <Color x:Key="StatusSuccessColor">#FF2ECC71</Color>
    <Color x:Key="StatusErrorColor">#FFE74C3C</Color>

    <!-- Brushes from Colors -->
    <SolidColorBrush x:Key="SurfaceDeepBrush"    Color="{StaticResource SurfaceDeepColor}"/>
    <SolidColorBrush x:Key="SurfacePrimaryBrush"  Color="{StaticResource SurfacePrimaryColor}"/>
    <SolidColorBrush x:Key="SurfaceElevatedBrush" Color="{StaticResource SurfaceElevatedColor}"/>
    <SolidColorBrush x:Key="SurfaceBorderBrush"   Color="{StaticResource SurfaceBorderColor}"/>
    <SolidColorBrush x:Key="SurfaceHoverBrush"    Color="{StaticResource SurfaceHoverColor}"/>

    <SolidColorBrush x:Key="TextPrimaryBrush"   Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextDisabledBrush"  Color="{StaticResource TextDisabledColor}"/>

    <SolidColorBrush x:Key="AccentRedBrush"      Color="{StaticResource AccentRedColor}"/>
    <SolidColorBrush x:Key="AccentRedHoverBrush" Color="{StaticResource AccentRedHoverColor}"/>
    <SolidColorBrush x:Key="AccentBlueBrush"     Color="{StaticResource AccentBlueColor}"/>

    <SolidColorBrush x:Key="StatusRecordingBrush" Color="{StaticResource StatusRecordingColor}"/>
    <SolidColorBrush x:Key="StatusPausedBrush"    Color="{StaticResource StatusPausedColor}"/>
    <SolidColorBrush x:Key="StatusIdleBrush"      Color="{StaticResource StatusIdleColor}"/>
    <SolidColorBrush x:Key="StatusSuccessBrush"   Color="{StaticResource StatusSuccessColor}"/>
    <SolidColorBrush x:Key="StatusErrorBrush"     Color="{StaticResource StatusErrorColor}"/>

    <!-- Transparent -->
    <SolidColorBrush x:Key="TransparentBrush" Color="Transparent"/>

</ResourceDictionary>
