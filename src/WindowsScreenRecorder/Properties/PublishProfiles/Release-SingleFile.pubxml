<?xml version="1.0" encoding="utf-8"?>
<!--
    Visual Studio Publish Profile — Windows Screen Recorder
    Produces a single self-contained executable for Windows x64.

    Usage (MSBuild):
        dotnet publish -p:PublishProfile=Release-SingleFile -r win-x64

    Usage (Visual Studio):
        Right-click project → Publish → select this profile
-->
<Project>
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <Platform>x64</Platform>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <PublishSingleFile>true</PublishSingleFile>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
    <EnableCompressionInSingleFile>true</EnableCompressionInSingleFile>
    <PublishReadyToRun>true</PublishReadyToRun>
    <TieredPGO>true</TieredPGO>
    <PublishDir>$(MSBuildThisFileDirectory)..\..\..\..\publish\</PublishDir>
    <WebPublishMethod>FileSystem</WebPublishMethod>
    <LastUsedBuildConfiguration>Release</LastUsedBuildConfiguration>
    <LastUsedPlatform>x64</LastUsedPlatform>
    <ExcludeNativeLibrariesForSelfExtract>false</ExcludeNativeLibrariesForSelfExtract>
  </PropertyGroup>
</Project>
